{
  "name": "@keepitfresh/openfoodfacts-importer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenFoodFacts importer scaffold for KeepItFresh (Phase 0)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/storage_predictor.test.ts",
    "preflight": "bash ./scripts/preflight.sh",
    "daily:run": "bash ./scripts/run-daily-import.sh",
    "logs:rotate": "bash ./scripts/rotate-logs.sh",
    "rollout:plan": "tsx src/cli/index.ts rollout:plan",
    "sample": "tsx src/cli/index.ts sample",
    "schema:probe": "tsx src/cli/index.ts schema:probe",
    "compare:contract": "tsx src/cli/index.ts compare:contract",
    "phase2": "tsx src/cli/index.ts phase2",
    "categories:signals": "tsx src/cli/index.ts categories:signals",
    "categories:build": "tsx src/cli/index.ts categories:build",
    "phase3": "tsx src/cli/index.ts phase3",
    "transform:sample": "tsx src/cli/index.ts transform:sample",
    "validate:products": "tsx src/cli/index.ts validate:products",
    "phase4": "tsx src/cli/index.ts phase4",
    "phase5:dryrun": "tsx src/cli/index.ts importProducts --dry-run --file ../../../openfoodfacts-products.jsonl --max-lines 1000 --max-writes 500",
    "import:categories": "tsx src/cli/index.ts importCategories",
    "import:products": "tsx src/cli/index.ts importProducts",
    "verify:run": "tsx src/cli/index.ts verify:run"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.7.0",
    "pino": "^9.4.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
